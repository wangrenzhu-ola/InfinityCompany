#!/usr/bin/env python3
import subprocess
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
CLI = SCRIPT_DIR / "cli.py"

USAGE = """Usage:
  acpx-infinity <agent_id> <message>
  acpx-infinity broadcast --targets <all|role:<role>|ids:a,b> --message <content>
  acpx-infinity status <agent_id>
  acpx-infinity history [--limit N] [--sender id] [--target id]
"""


def main() -> int:
    args = sys.argv[1:]
    if not args:
        print(USAGE, end="")
        return 1

    cmd = args[0]
    if cmd == "broadcast":
        argv = [sys.executable, str(CLI), "acpx-broadcast", *args[1:]]
    elif cmd == "status":
        argv = [sys.executable, str(CLI), "acpx-status", *args[1:]]
    elif cmd == "history":
        argv = [sys.executable, str(CLI), "acpx-history", *args[1:]]
    else:
        if len(args) < 2:
            print(USAGE, end="")
            return 1
        target_id, message = args[0], args[1]
        argv = [sys.executable, str(CLI), "acpx-send", target_id, message, *args[2:]]

    return subprocess.call(argv)


if __name__ == "__main__":
    raise SystemExit(main())
