#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI="$SCRIPT_DIR/cli.py"

usage() {
  echo "Usage:"
  echo "  acpx-infinity <agent_id> <message>"
  echo "  acpx-infinity broadcast --targets <all|role:<role>|ids:a,b> --message <content>"
  echo "  acpx-infinity status <agent_id>"
  echo "  acpx-infinity history [--limit N] [--sender id] [--target id]"
}

if [ $# -lt 1 ]; then
  usage
  exit 1
fi

case "$1" in
  broadcast)
    shift
    python3 "$CLI" acpx-broadcast "$@"
    ;;
  status)
    shift
    python3 "$CLI" acpx-status "$@"
    ;;
  history)
    shift
    python3 "$CLI" acpx-history "$@"
    ;;
  *)
    if [ $# -lt 2 ]; then
      usage
      exit 1
    fi
    target_id="$1"
    message="$2"
    shift 2
    python3 "$CLI" acpx-send "$target_id" "$message" "$@"
    ;;
esac
