#!/bin/bash
# InfinityCompany 跨Agent通信工具
# 替代原生acpx，支持虚拟公司agent ID

set -e

AGENT_ID=$1
MESSAGE=$2

if [ -z "$AGENT_ID" ] || [ -z "$MESSAGE" ]; then
    echo "Usage: acpx-infinity <agent_id> <message>"
    echo "Example: acpx-infinity zhangliang '你好，我是韩信'"
    exit 1
fi

# 使用openclaw agent命令实现跨Agent通信
openclaw agent --agent "$AGENT_ID" --message "$MESSAGE" 2>/dev/null | grep -v "\[plugins\]" | tail -50
